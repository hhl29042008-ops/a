-- =============== CULL / DISABLE ===============
local ZERO_RANGE = NumberRange.new(0,0)
local EMPTY_ASSET = "rbxassetid://0"

local function shouldSkipChar(inst)
  if not LP or not LP.Character then return false end
  return (not CFG.hide.includeCharacter) and inst:IsDescendantOf(LP.Character)
end

local function hideGeometry(inst)
  -- áº¨n má»i BasePart/MeshPart/UnionOperation
  if not CFG.hide.geometry then return end
  if inst:IsA("BasePart") then
    if CFG.hide.includeCharacter or not shouldSkipChar(inst) then
      if inst.Transparency ~= 1 then inst.Transparency = 1 end
      if CFG.hide.castShadowOff and inst.CastShadow ~= false then inst.CastShadow = false end
      if CFG.hide.reflectance0 and inst.Reflectance ~= 0 then inst.Reflectance = 0 end
      if CFG.hide.materialPlastic and inst.Material ~= Enum.Material.Plastic then
        inst.Material = Enum.Material.Plastic
      end
    end
  end
end

local function cull(inst)
  if not inst or inst.Parent == nil then return end

  -- áº¨n hÃ¬nh há»c trÆ°á»›c
  hideGeometry(inst)
  if shouldSkipChar(inst) then return end

  -- Hiá»‡u á»©ng náº·ng
  if CFG.kill.particles and (
      inst:IsA("ParticleEmitter") or inst:IsA("Trail") or inst:IsA("Beam") or
      inst:IsA("Fire") or inst:IsA("Smoke") or inst:IsA("Sparkles")
    ) then
    if inst:IsA("ParticleEmitter") then
      inst.Enabled = false; inst.Rate = 0; inst.Lifetime = ZERO_RANGE
    else
      if inst.Enabled ~= nil then inst.Enabled = false end
    end
    return
  end

  -- ÄÃ¨n
  if CFG.kill.lights and (inst:IsA("PointLight") or inst:IsA("SpotLight") or inst:IsA("SurfaceLight")) then
    inst.Enabled = false
    return
  end

  -- Decal/Texture/SurfaceAppearance
  if CFG.kill.decals then
    if inst:IsA("Decal") or inst:IsA("Texture") then
      inst:Destroy(); return
    end
    if inst:IsA("SurfaceAppearance") then
      -- gá»¡ map Ä‘á»ƒ nháº¹ (hoáº·c Ä‘á»ƒ trá»‘ng)
      safe(nil, function() inst.ColorMap = EMPTY_ASSET end)
      safe(nil, function() inst.MetalnessMap = EMPTY_ASSET end)
      safe(nil, function() inst.RoughnessMap = EMPTY_ASSET end)
      safe(nil, function() inst.NormalMap = EMPTY_ASSET end)
      return
    end
  end

  -- UI 3D
  if CFG.kill.ui3d and (inst:IsA("BillboardGui") or inst:IsA("SurfaceGui")) then
    if inst.Enabled ~= nil then inst.Enabled = false else safe(nil, function() inst:Destroy() end) end
    return
  end

  -- Prompt
  if CFG.kill.prompts and inst:IsA("ProximityPrompt") then
    if inst.Enabled ~= nil then inst.Enabled = false else safe(nil, function() inst:Destroy() end) end
    return
  end

  -- Highlight
  if CFG.kill.highlights and inst:IsA("Highlight") then
    safe(nil, function() inst:Destroy() end)
    return
  end

  -- Explosion => giáº£m tÃ¡c Ä‘á»™ng
  if inst:IsA("Explosion") then
    inst.BlastPressure = 1; inst.BlastRadius = 1
    return
  end
end

-- =============== INITIAL SWEEP + STREAM HOOKS ===============
local processed = setmetatable({}, {__mode="k"})
local queue = {}

local function push(x) if x and not processed[x] then queue[#queue+1] = x; processed[x] = true end end
local function pop()
  local n = #queue
  if n == 0 then return end
  local v = queue[n]; queue[n] = nil; return v
end

local function enqueueDescendants(root)
  for _, v in ipairs(root:GetDescendants()) do push(v) end
end

enqueueDescendants(Workspace)
enqueueDescendants(Lighting)

if CFG.hookNewSpawn then
  Workspace.DescendantAdded:Connect(push)
  Lighting.DescendantAdded:Connect(push)
end

RunService.Heartbeat:Connect(function()
  local n = 0
  while n < CFG.batchSize do
    local obj = pop()
    if not obj then break end
    if obj.Parent ~= nil then cull(obj) end
    n += 1
  end
end)

-- =============== CHARACTER SIMPLIFY ===============
local function simplifyCharacter(char)
  if not char then return end

  -- Gá»¡ accessory
  if CFG.kill.accessories then
    for _, ch in ipairs(char:GetChildren()) do
      if ch:IsA("Accessory") then safe(nil, function() ch:Destroy() end) end
    end
  end

  -- Gá»¡ quáº§n Ã¡o
  if CFG.kill.clothes then
    for _, ch in ipairs(char:GetChildren()) do
      if ch:IsA("Shirt") or ch:IsA("Pants") or ch:IsA("ShirtGraphic") then
        safe(nil, function() ch:Destroy() end)
      end
    end
  end

  -- Táº¯t Animate
  local animate = char:FindFirstChild("Animate")
  if animate and animate:IsA("LocalScript") then
    safe(nil, function() animate.Disabled = true end)
  end

  -- áº¨n hÃ¬nh há»c cá»§a nhÃ¢n váº­t náº¿u báº­t includeCharacter
  if CFG.hide.includeCharacter and CFG.hide.geometry then
    for _, part in ipairs(char:GetDescendants()) do
      if part:IsA("BasePart") then
        if part.Transparency ~= 1 then part.Transparency = 1 end
        if CFG.hide.castShadowOff and part.CastShadow ~= false then part.CastShadow = false end
        if CFG.hide.reflectance0 and part.Reflectance ~= 0 then part.Reflectance = 0 end
        if CFG.hide.materialPlastic and part.Material ~= Enum.Material.Plastic then
          part.Material = Enum.Material.Plastic
        end
      end
    end
  end

  -- Táº¯t UI 3D gáº¯n trÃªn nhÃ¢n váº­t
  if CFG.kill.ui3d then
    for _, ch in ipairs(char:GetDescendants()) do
      if ch:IsA("BillboardGui") or ch:IsA("SurfaceGui") then
        if ch.Enabled ~= nil then ch.Enabled = false else safe(nil, function() ch:Destroy() end) end
      end
    end
  end
end

