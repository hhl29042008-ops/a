
-- BOOST.lua ГўвӮ¬вҖқ Automation optimizer (no collectgarbage)
-- ThГғВӘm tГғВӯnh nГ„Ж’ng: hide geometry (Г„вҖҳГЎВәВ·t Transparency = 1) Г„вҖҳГЎВ»Ж’ "tГғ ng hГғВ¬nh" mГЎВ»ВҚi part
-- MГЎВ»ВҘc tiГғВӘu: no-render, FPS cap thГЎВәВҘp, tГЎВәВҜt ГғВўm/GUI, diГЎВ»вҖЎt hiГЎВ»вҖЎu ГЎВ»В©ng nГЎВәВ·ng, dГЎВ»ВҚn Г„вҖҳГЎВ»вҖң thГЎВ»В«a.

-- =============== CONFIG ===============
local CFG = {
  disable3D       = true,   -- tГЎВәВҜt render 3D nГЎВәВҝu API cГғ
  soundOff        = true,   -- tГЎВәВҜt ГғВўm
  disableCoreGui  = true,   -- ГЎВәВ©n CoreGui (chat, backpackГўвӮ¬ВҰ)
  lowQuality      = true,   -- ГғВ©p quality level = 1
  postFXOff       = true,   -- tГЎВәВҜt Blur/SunRays/ColorCorrection/Bloom/DoF
  zeroWater       = true,   -- tГЎВәВҜt hiГЎВ»вҖЎu ГЎВ»В©ng nГҶВ°ГЎВ»вҖәc (vГғ  lГғ m nГҶВ°ГЎВ»вҖәc trong suГЎВ»вҖҳt)
  hide = {
    geometry      = false,   -- <-- ГЎВәВЁN HГЎВәВҫT BasePart/MeshPart/UnionOperation (Transparency = 1)
    castShadowOff = false,   -- tГЎВәВҜt Г„вҖҳГЎВ»вҖў bГғВіng luГғВҙn cho chГЎВәВҜc
    reflectance0  = false,   -- Г„вҖҳГЎВәВ·t Reflectance = 0
    materialPlastic = false,-- nГЎВәВҝu muГЎВ»вҖҳn thГғВ¬ chuyГЎВ»Ж’n vГЎВ»ВҒ Plastic (Г„вҖҳГЎВ»Ж’ debug bГЎВәВӯt render vГЎВәВ«n nhГЎВәВ№)
    includeCharacter = false,-- true nГЎВәВҝu muГЎВ»вҖҳn ГЎВәВ©n cГЎВәВЈ nhГғВўn vГЎВәВӯt cГЎВ»В§a bГЎВәВЎn
  },
  kill = {
    particles     = true,   -- ParticleEmitter/Trail/Beam/Fire/Smoke/Sparkles
    lights        = true,   -- PointLight/SpotLight/SurfaceLight
    decals        = true,   -- Decal/Texture/SurfaceAppearance
    ui3d          = true,   -- BillboardGui/SurfaceGui
    prompts       = false,  -- ProximityPrompt (true nГЎВәВҝu bot khГғВҙng cГЎВәВ§n)
    highlights    = true,   -- Highlight
    clothes       = true,   -- Shirt/Pants/ShirtGraphic
    accessories   = true,   -- Accessory trГғВӘn nhГғВўn vГЎВәВӯt
  },
  batchSize       = 2000,   -- sГЎВ»вҖҳ object xГЎВ»Вӯ lГғВҪ mГЎВ»вҖ”i frame (tГ„Ж’ng nГЎВәВҝu muГЎВ»вҖҳn ГўвӮ¬Е“quГғВ©tГўвӮ¬Вқ nhanh hГҶВЎn)
  hookNewSpawn    = true,   -- auto xГЎВ»Вӯ lГғВҪ object mГЎВ»вҖәi spawn
  antiAFK         = true,   -- chГЎВ»вҖҳng kick AFK
}

-- =============== SERVICES ===============
local S = setmetatable({}, {__index=function(t,k)local s=game:GetService(k) rawset(t,k,s) return s end})
local RunService, Workspace, Lighting, Players, StarterGui, SoundService, UIS =
  S.RunService, S.Workspace, S.Lighting, S.Players, S.StarterGui, S.SoundService, S.UserInputService

local LP = Players.LocalPlayer

-- =============== HELPERS ===============
local function safe(_, f) local ok = pcall(f); return ok end

local function setNoRender(on)
  if RunService and RunService.Set3dRenderingEnabled then
    safe(nil, function() RunService:Set3dRenderingEnabled(on == false and false or true) end)
  end
end



local function setCoreGuiEnabled(on)
  safe(nil, function()
    for _, t in ipairs(Enum.CoreGuiType:GetEnumItems()) do
      StarterGui:SetCoreGuiEnabled(t, on)
    end
  end)
end

local function setLowQuality()
  safe(nil, function() settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 end)
end

local function killPostFX()
  for _, e in ipairs(Lighting:GetChildren()) do
    if e:IsA("BlurEffect") or e:IsA("SunRaysEffect") or e:IsA("ColorCorrectionEffect")
      or e:IsA("BloomEffect") or e:IsA("DepthOfFieldEffect") then
      e.Enabled = false
    end
  end
end

local function waterZero()
  local t = Workspace.Terrain
  -- LГғ m nГҶВ°ГЎВ»вҖәc Г„вҖҳГЎВ»В©ng im & TRONG SUГЎВ»ВҗT Г„вҖҳГЎВ»Ж’ "hide"
  t.WaterWaveSize, t.WaterWaveSpeed = 0, 0
  t.WaterReflectance = 0
  t.WaterTransparency = 1
end

local function antiAFK()
  if not CFG.antiAFK then return end
  safe(nil, function()
    local vu = S.VirtualUser
    Players.LocalPlayer.Idled:Connect(function()
      vu:CaptureController(); vu:ClickButton2(Vector2.new(0,0))
    end)
  end)
end

-- =============== ONE-TIME TOGGLES ===============
do
  if CFG.soundOff then safe(nil, function() UserSettings():GetService("UserGameSettings").MasterVolume = 0 end) end
  if CFG.disableCoreGui then setCoreGuiEnabled(false) end
  if CFG.lowQuality then setLowQuality() end
  if CFG.postFXOff then killPostFX() end
  if CFG.zeroWater then waterZero() end
  if CFG.disable3D then setNoRender(false) end

  antiAFK()
end

-- =============== CULL / DISABLE ===============
local ZERO_RANGE = NumberRange.new(0,0)
local EMPTY_ASSET = "rbxassetid://0"

local function shouldSkipChar(inst)
  if not LP or not LP.Character then return false end
  return (not CFG.hide.includeCharacter) and inst:IsDescendantOf(LP.Character)
end

local function hideGeometry(inst)
  -- ГЎВәВЁn mГЎВ»ВҚi BasePart/MeshPart/UnionOperation
  if not CFG.hide.geometry then return end
  if inst:IsA("BasePart") then
    if CFG.hide.includeCharacter or not shouldSkipChar(inst) then
      if inst.Transparency ~= 1 then inst.Transparency = 1 end
      if CFG.hide.castShadowOff and inst.CastShadow ~= false then inst.CastShadow = false end
      if CFG.hide.reflectance0 and inst.Reflectance ~= 0 then inst.Reflectance = 0 end
      if CFG.hide.materialPlastic and inst.Material ~= Enum.Material.Plastic then
        inst.Material = Enum.Material.Plastic
      end
    end
  end
end

local function cull(inst)
  if not inst or inst.Parent == nil then return end

  -- ГЎВәВЁn hГғВ¬nh hГЎВ»ВҚc trГҶВ°ГЎВ»вҖәc
  hideGeometry(inst)
  if shouldSkipChar(inst) then return end

  -- HiГЎВ»вҖЎu ГЎВ»В©ng nГЎВәВ·ng
  if CFG.kill.particles and (
      inst:IsA("ParticleEmitter") or inst:IsA("Trail") or inst:IsA("Beam") or
      inst:IsA("Fire") or inst:IsA("Smoke") or inst:IsA("Sparkles")
    ) then
    if inst:IsA("ParticleEmitter") then
      inst.Enabled = false; inst.Rate = 0; inst.Lifetime = ZERO_RANGE
    else
      if inst.Enabled ~= nil then inst.Enabled = false end
    end
    return
  end

  -- Г„ВҗГғВЁn
  if CFG.kill.lights and (inst:IsA("PointLight") or inst:IsA("SpotLight") or inst:IsA("SurfaceLight")) then
    inst.Enabled = false
    return
  end

  -- Decal/Texture/SurfaceAppearance
  if CFG.kill.decals then
    if inst:IsA("Decal") or inst:IsA("Texture") then
      inst:Destroy(); return
    end
    if inst:IsA("SurfaceAppearance") then
      -- gГЎВ»ВЎ map Г„вҖҳГЎВ»Ж’ nhГЎВәВ№ (hoГЎВәВ·c Г„вҖҳГЎВ»Ж’ trГЎВ»вҖҳng)
      safe(nil, function() inst.ColorMap = EMPTY_ASSET end)
      safe(nil, function() inst.MetalnessMap = EMPTY_ASSET end)
      safe(nil, function() inst.RoughnessMap = EMPTY_ASSET end)
      safe(nil, function() inst.NormalMap = EMPTY_ASSET end)
      return
    end
  end

  -- UI 3D
  if CFG.kill.ui3d and (inst:IsA("BillboardGui") or inst:IsA("SurfaceGui")) then
    if inst.Enabled ~= nil then inst.Enabled = false else safe(nil, function() inst:Destroy() end) end
    return
  end

  -- Prompt
  if CFG.kill.prompts and inst:IsA("ProximityPrompt") then
    if inst.Enabled ~= nil then inst.Enabled = false else safe(nil, function() inst:Destroy() end) end
    return
  end

  -- Highlight
  if CFG.kill.highlights and inst:IsA("Highlight") then
    safe(nil, function() inst:Destroy() end)
    return
  end

  -- Explosion => giГЎВәВЈm tГғВЎc Г„вҖҳГЎВ»в„ўng
  if inst:IsA("Explosion") then
    inst.BlastPressure = 1; inst.BlastRadius = 1
    return
  end
end

-- =============== INITIAL SWEEP + STREAM HOOKS ===============
local processed = setmetatable({}, {__mode="k"})
local queue = {}

local function push(x) if x and not processed[x] then queue[#queue+1] = x; processed[x] = true end end
local function pop()
  local n = #queue
  if n == 0 then return end
  local v = queue[n]; queue[n] = nil; return v
end

local function enqueueDescendants(root)
  for _, v in ipairs(root:GetDescendants()) do push(v) end
end

enqueueDescendants(Workspace)
enqueueDescendants(Lighting)

if CFG.hookNewSpawn then
  Workspace.DescendantAdded:Connect(push)
  Lighting.DescendantAdded:Connect(push)
end

RunService.Heartbeat:Connect(function()
  local n = 0
  while n < CFG.batchSize do
    local obj = pop()
    if not obj then break end
    if obj.Parent ~= nil then cull(obj) end
    n += 1
  end
end)

-- =============== CHARACTER SIMPLIFY ===============
local function simplifyCharacter(char)
  if not char then return end

  -- GГЎВ»ВЎ accessory
  if CFG.kill.accessories then
    for _, ch in ipairs(char:GetChildren()) do
      if ch:IsA("Accessory") then safe(nil, function() ch:Destroy() end) end
    end
  end

  -- GГЎВ»ВЎ quГЎВәВ§n ГғВЎo
  if CFG.kill.clothes then
    for _, ch in ipairs(char:GetChildren()) do
      if ch:IsA("Shirt") or ch:IsA("Pants") or ch:IsA("ShirtGraphic") then
        safe(nil, function() ch:Destroy() end)
      end
    end
  end

  -- TГЎВәВҜt Animate
  local animate = char:FindFirstChild("Animate")
  if animate and animate:IsA("LocalScript") then
    safe(nil, function() animate.Disabled = true end)
  end

  -- ГЎВәВЁn hГғВ¬nh hГЎВ»ВҚc cГЎВ»В§a nhГғВўn vГЎВәВӯt nГЎВәВҝu bГЎВәВӯt includeCharacter
  if CFG.hide.includeCharacter and CFG.hide.geometry then
    for _, part in ipairs(char:GetDescendants()) do
      if part:IsA("BasePart") then
        if part.Transparency ~= 1 then part.Transparency = 1 end
        if CFG.hide.castShadowOff and part.CastShadow ~= false then part.CastShadow = false end
        if CFG.hide.reflectance0 and part.Reflectance ~= 0 then part.Reflectance = 0 end
        if CFG.hide.materialPlastic and part.Material ~= Enum.Material.Plastic then
          part.Material = Enum.Material.Plastic
        end
      end
    end
  end

  -- TГЎВәВҜt UI 3D gГЎВәВҜn trГғВӘn nhГғВўn vГЎВәВӯt
  if CFG.kill.ui3d then
    for _, ch in ipairs(char:GetDescendants()) do
      if ch:IsA("BillboardGui") or ch:IsA("SurfaceGui") then
        if ch.Enabled ~= nil then ch.Enabled = false else safe(nil, function() ch:Destroy() end) end
      end
    end
  end
end

if LP then
  if LP.Character then simplifyCharacter(LP.Character) end
  LP.CharacterAdded:Connect(function(c)
    c:WaitForChild("HumanoidRootPart", 10)
    simplifyCharacter(c)
  end)
end



print("[BOOST] Applied: no-render=", CFG.disable3D,
      " postFX=", CFG.postFXOff, " water0=", CFG.zeroWater,
